<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/redlist_widget_background"
    android:minHeight="140dp">

    <!-- Compact Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💱 Rates"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/redlist_refresh_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="🔄"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/redlist_refresh_button_background"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Refresh rates" />

    </LinearLayout>

    <!-- Currency Grid Container -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3"
        android:alignmentMode="alignMargins"
        android:useDefaultMargins="true">

        <!-- Currency Card 1 - USD -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:background="@drawable/currency_card_background"
            android:padding="6dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/flag_1"
                    android:layout_width="16dp"
                    android:layout_height="12dp"
                    android:src="@drawable/flag_us"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/country_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="USD"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/rate_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Currency Card 2 - EUR -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:background="@drawable/currency_card_background"
            android:padding="6dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/flag_2"
                    android:layout_width="16dp"
                    android:layout_height="12dp"
                    android:src="@drawable/flag_eu"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/country_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EUR"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/rate_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.8500"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Currency Card 3 - JPY -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:background="@drawable/currency_card_background"
            android:padding="6dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/flag_3"
                    android:layout_width="16dp"
                    android:layout_height="12dp"
                    android:src="@drawable/flag_jp"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/country_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="JPY"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/rate_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="150.25"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Currency Card 4 - GBP -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:background="@drawable/currency_card_background"
            android:padding="6dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/flag_4"
                    android:layout_width="16dp"
                    android:layout_height="12dp"
                    android:src="@drawable/flag_gb"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/country_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="GBP"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/rate_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.7500"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Currency Card 5 - PKR -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:background="@drawable/currency_card_background"
            android:padding="6dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/flag_5"
                    android:layout_width="16dp"
                    android:layout_height="12dp"
                    android:src="@drawable/flag_pk"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/country_5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PKR"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/rate_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="280.50"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Currency Card 6 - INR -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:background="@drawable/currency_card_background"
            android:padding="6dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/flag_6"
                    android:layout_width="16dp"
                    android:layout_height="12dp"
                    android:src="@drawable/flag_in"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/country_6"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="INR"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/rate_6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="83.25"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </GridLayout>

    <!-- Compact Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/last_updated"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🕐 Just now"
            android:textSize="9sp"
            android:textColor="#666666"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:id="@+id/internet_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="9sp"
            android:textColor="#F44336"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
