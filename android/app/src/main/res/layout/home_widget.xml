<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/widget_background"
    android:minHeight="180dp">

    <!-- Simple Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CurrenSee Pro"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1E3A8A" />

        <TextView
            android:id="@+id/widget_refresh_btn"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:text="🔄"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/refresh_button_background"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Refresh rates" />

    </LinearLayout>

    <!-- Amount Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/amount_input_background"
        android:padding="8dp"
        android:layout_marginBottom="6dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_currency_symbol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/widget_amount_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1.00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="start|center_vertical"
            android:background="@drawable/amount_text_background"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Tap to edit amount" />

    </LinearLayout>

    <!-- Currency Selection -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <!-- From Currency -->
        <LinearLayout
            android:id="@+id/widget_from_currency_container"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/currency_selector_background"
            android:padding="6dp"
            android:layout_marginEnd="3dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/widget_from_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🇺🇸"
                android:textSize="18sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/widget_from_currency"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="USD"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:gravity="center" />

        </LinearLayout>

        <!-- Swap Button -->
        <TextView
            android:id="@+id/widget_swap_arrow"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="⇅"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/swap_button_background"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginHorizontal="3dp"
            android:contentDescription="Swap currencies" />

        <!-- To Currency -->
        <LinearLayout
            android:id="@+id/widget_to_currency_container"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/currency_selector_background"
            android:padding="6dp"
            android:layout_marginStart="3dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/widget_to_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🇵🇰"
                android:textSize="18sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/widget_to_currency"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PKR"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

    <!-- Result Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rate_info_background"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Result"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/widget_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00 PKR"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1E293B" />

        <TextView
            android:id="@+id/widget_rate_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 USD = 0.00 PKR"
            android:textSize="10sp"
            android:textColor="#64748B"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widget_last_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Updated: Just now"
            android:textSize="8sp"
            android:textColor="#94A3B8"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Numeric Keypad (Hidden by default) -->
    <LinearLayout
        android:id="@+id/widget_keypad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F8FAFC"
        android:padding="4dp"
        android:visibility="gone"
        android:layout_marginTop="6dp">

        <!-- Keypad Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/btn_1" android:text="1" style="@style/WidgetKeypadButton" />
                <Button android:id="@+id/btn_2" android:text="2" style="@style/WidgetKeypadButton" />
                <Button android:id="@+id/btn_3" android:text="3" style="@style/WidgetKeypadButton" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/btn_4" android:text="4" style="@style/WidgetKeypadButton" />
                <Button android:id="@+id/btn_5" android:text="5" style="@style/WidgetKeypadButton" />
                <Button android:id="@+id/btn_6" android:text="6" style="@style/WidgetKeypadButton" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/btn_7" android:text="7" style="@style/WidgetKeypadButton" />
                <Button android:id="@+id/btn_8" android:text="8" style="@style/WidgetKeypadButton" />
                <Button android:id="@+id/btn_9" android:text="9" style="@style/WidgetKeypadButton" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/btn_dot" android:text="." style="@style/WidgetKeypadButton" />
                <Button android:id="@+id/btn_0" android:text="0" style="@style/WidgetKeypadButton" />
                <Button android:id="@+id/btn_clear" android:text="C" style="@style/WidgetKeypadButton" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/btn_done" android:text="Done" style="@style/WidgetDoneButton" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout> 